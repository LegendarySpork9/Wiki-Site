@page "/categories/create"

<PageTitle>New Category - Knowledge Base</PageTitle>

<div class="create-category-container">
    <h1>Create New Category</h1>

    @if (!User.IsLoggedIn || !User.Admin)
    {
        <div class="alert alert-warning">You must be logged in as an admin to create categories.</div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success">@_successMessage</div>
        }

        <div class="card" style="@StyleConverter.GetCardDarkMode(User.DarkMode)">
            <div class="card-body">
                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <input type="text" class="form-control" id="name" @bind="_name"
                           style="@StyleConverter.GetInputDarkMode(User.DarkMode)" />
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <input type="text" class="form-control" id="description" @bind="_description"
                           placeholder="Brief description of this category"
                           style="@StyleConverter.GetInputDarkMode(User.DarkMode)" />
                </div>

                <div class="mb-3">
                    <label for="icon" class="form-label">Icon</label>
                    <input type="text" class="form-control" id="icon" @bind="_icon"
                           placeholder="e.g. bi-folder, bi-globe, bi-person-badge"
                           style="@StyleConverter.GetInputDarkMode(User.DarkMode)" />
                    <div class="form-text" style="@StyleConverter.GetTextMutedDarkMode(User.DarkMode)">
                        Bootstrap icon class name. Leave blank for default.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="parentCategory" class="form-label">Parent Category</label>
                    <select class="form-select" id="parentCategory" @bind="_selectedParentId"
                            style="@StyleConverter.GetInputDarkMode(User.DarkMode)">
                        <option value="">None (top-level category)</option>
                        @if (_categories != null)
                        {
                            @foreach (var cat in _flatCategories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                </div>

                <button class="btn btn-primary" @onclick="HandleCreate" disabled="@_saving">
                    @if (_saving)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <span>Create Category</span>
                    }
                </button>
                <a href="/" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </div>
    }
</div>
