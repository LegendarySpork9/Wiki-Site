@page "/images/library"

<PageTitle>Image Library - Knowledge Base</PageTitle>

<div class="image-library-container">
    <h1>Image Library</h1>

    @if (!User.IsLoggedIn || !User.Admin)
    {
        <div class="alert alert-warning">You must be logged in as an admin to manage images.</div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger">@_errorMessage</div>
        }

        @if (!string.IsNullOrEmpty(_successMessage))
        {
            <div class="alert alert-success">@_successMessage</div>
        }

        <!-- Upload Section -->
        <div class="card mb-4" style="@StyleConverter.GetCardDarkMode(User.DarkMode)">
            <div class="card-body">
                <h5 class="card-title">Upload Image</h5>
                <div class="d-flex align-items-center gap-3">
                    <InputFile OnChange="OnFileSelected" accept="@_acceptFormats"
                               class="@($"form-control{(User.DarkMode ? " form-control-dark" : "")}")"
                               style="@StyleConverter.GetInputDarkMode(User.DarkMode)" />
                    <button class="btn btn-primary flex-shrink-0" @onclick="HandleUpload"
                            disabled="@(_selectedFile == null || _uploading)">
                        @if (_uploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Uploading...</span>
                        }
                        else
                        {
                            <span class="bi bi-upload me-1"></span>
                            <span>Upload</span>
                        }
                    </button>
                </div>
                @if (_selectedFile != null)
                {
                    <div class="mt-2" style="@StyleConverter.GetTextMutedDarkMode(User.DarkMode)">
                        <small>Selected: @_selectedFile.Name (@FormatFileSize(_selectedFile.Size))</small>
                    </div>
                }
            </div>
        </div>

        <!-- Image Gallery -->
        @if (_loading)
        {
            <div class="text-center mt-4">
                <div class="spinner-border" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        }
        else if (_images != null && _images.Images.Any())
        {
            <div class="image-grid">
                @foreach (var image in _images.Images)
                {
                    <div class="card image-card" style="@StyleConverter.GetCardDarkMode(User.DarkMode)">
                        <div class="image-preview" style="@(User.DarkMode ? "background-color: #2A2A2A;" : "")">
                            <img src="@image.Url" alt="@image.FileName" loading="lazy" />
                        </div>
                        <div class="card-body">
                            <h6 class="card-title text-truncate" title="@($"{image.FileName}{image.Extension}")">
                                @($"{image.FileName}{image.Extension}")
                            </h6>
                            <div class="image-details" style="@StyleConverter.GetTextMutedDarkMode(User.DarkMode)">
                                <small>
                                    <span class="badge bg-secondary me-1">@image.Extension</span>
                                    @FormatFileSize(image.FileSize)
                                </small>
                                <br />
                                <small>Created: @image.DateCreated.ToString("dd MMM yyyy")</small>
                                <br />
                                <small>Uploaded: @image.DateUploaded.ToString("dd MMM yyyy")</small>
                            </div>
                            <div class="mt-2">
                                @if (_confirmDeleteId == image.Id)
                                {
                                    <span class="me-2" style="@StyleConverter.GetTextMutedDarkMode(User.DarkMode)">
                                        <small>Delete?</small>
                                    </span>
                                    <button class="btn btn-danger btn-sm me-1" @onclick="() => ConfirmDelete(image.Id)"
                                            disabled="@_deleting">
                                        @if (_deleting)
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                        }
                                        else
                                        {
                                            <span>Yes</span>
                                        }
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="CancelDelete">No</button>
                                }
                                else
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RequestDelete(image.Id)">
                                        <span class="bi bi-trash me-1"></span>Delete
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (_images.MultiplePages)
            {
                <nav class="mt-3">
                    <ul class="pagination">
                        @for (int i = 1; i <= _images.PageCount; i++)
                        {
                            int pageNum = i;
                            <li class="page-item @(pageNum == _currentPage ? "active" : "")">
                                <button class="page-link" @onclick="() => LoadPage(pageNum)"
                                        style="@StyleConverter.GetCardDarkMode(User.DarkMode)">
                                    @pageNum
                                </button>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <p class="mt-3">No images in the library yet. Upload one to get started.</p>
        }
    }
</div>
