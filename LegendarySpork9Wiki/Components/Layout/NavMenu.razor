<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <span class="bi-book-nav-icon"></span> Knowledge Base
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (_categories != null)
        {
            @foreach (var category in _categories)
            {
                <div class="nav-item px-3">
                    <a class="nav-link @(IsCategoryActive(category) ? "active" : "")" href="@($"category/{category.Id}")">
                        <span class="bi bi-folder-nav-menu" aria-hidden="true"></span> @category.Name
                    </a>
                </div>
            }
        }

        @if (User is { IsLoggedIn: true, Admin: true })
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="categories/create">
                    <span class="bi bi-plus-nav-menu" aria-hidden="true"></span> New Category
                </NavLink>
            </div>
        }
    </nav>
</div>
